rules_version = '2';

// MwanaAI Firestore security rules.
//
// Apply these in the Firebase console:
//   Firestore Database > Rules > paste > Publish.
// Or with the Firebase CLI: `firebase deploy --only firestore:rules`.
//
// Model: every user can write only their OWN data. Progress data
// (quiz results, lesson completion) and user profiles are readable by any
// signed-in user so that teachers can see their class rosters and parents can
// see their child's progress.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function myUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperadmin() {
      return signedIn() && myUser().userType == 'superadmin';
    }

    // A School Admin: a delegate who manages teachers & students for one school.
    function isSchoolAdmin() {
      return signedIn() && myUser().userType == 'admin';
    }

    // The role a write is trying to set ('' if the write doesn't set one).
    function newRole() {
      return request.resource.data.get('userType', '');
    }

    // True if an invite addressed to THIS user's email (at the school named in
    // the write) grants `role`. This is how an invited admin self-configures.
    function invitedAs(role) {
      return request.resource.data.get('schoolId', '') != ''
        && exists(/databases/$(database)/documents/invites/$(request.resource.data.schoolId + '_' + request.auth.token.email))
        && get(/databases/$(database)/documents/invites/$(request.resource.data.schoolId + '_' + request.auth.token.email)).data.role == role;
    }

    // A user may set only non-privileged roles on themselves (the public
    // sign-up form). 'admin' requires a matching invite. 'superadmin' can NEVER
    // be set from the client — it is assigned out-of-band (console / backend).
    function roleAllowed() {
      return newRole() == '' || newRole() == 'student' || newRole() == 'teacher' || newRole() == 'parent'
        || (newRole() == 'admin' && invitedAs('admin'));
    }

    // A self-edit must not touch the account's lifecycle status — only an admin
    // can activate/deactivate/archive an account (see the admin path below).
    function statusUnchanged() {
      return request.resource.data.get('status', resource.data.get('status', 'active'))
        == resource.data.get('status', 'active');
    }

    // The keys an admin is permitted to change on someone else's profile: just
    // the account-lifecycle fields, nothing personal and never the role.
    function adminLifecycleOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'deactivatedAt', 'deactivatedBy', 'archivedAt', 'updatedAt']);
    }

    // User profiles — readable by signed-in users (rosters, parent lookup).
    // A user manages their OWN profile but cannot grant themselves a privileged
    // role (roleAllowed) or change their own status (statusUnchanged). A Super
    // Admin may toggle lifecycle on anyone; a School Admin only on a
    // teacher/student/parent in their own school.
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid && roleAllowed();
      allow update: if signedIn() && (
        (request.auth.uid == uid
          && (request.resource.data.get('userType', '') == resource.data.get('userType', '') || roleAllowed())
          && statusUnchanged())
        || (request.auth.uid != uid && adminLifecycleOnly() && (
              isSuperadmin()
              || (isSchoolAdmin()
                  && resource.data.get('schoolId', '') != ''
                  && resource.data.get('schoolId', '') == myUser().get('schoolId', '')
                  && resource.data.get('userType', '') in ['teacher', 'student', 'parent'])
           ))
      );
      allow delete: if signedIn() && request.auth.uid == uid;
    }

    // Saved tutor conversations — private to the owner.
    match /conversations/{id} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // Quiz results — readable by any signed-in user (teachers/parents view
    // progress); writable only by the owner.
    match /quiz_results/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // Lesson completion — same policy as quiz results.
    match /lesson_progress/{id} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // Classes — anyone signed in can read (to find a class by code); only the
    // owning teacher can create/modify.
    match /classes/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.teacherId == request.auth.uid;
    }

    // Class membership — students add/remove only their own membership;
    // any signed-in user can read (teacher rosters).
    match /class_members/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.studentId == request.auth.uid;
      allow delete: if signedIn() && resource.data.studentId == request.auth.uid;
    }

    // Assignments — readable by any signed-in user (students see their class's
    // tasks); only the owning teacher can create or remove them.
    match /assignments/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.teacherId == request.auth.uid;
    }

    // Schools — readable by any signed-in user (students/teachers see their
    // school); only a Super Admin can create or change them.
    match /schools/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isSuperadmin();
    }

    // Invites (admin roster) — a Super Admin manages all; a School Admin manages
    // teacher/student invites for their own school; an invitee can read and
    // accept their own invite (matched by email) when they sign up.
    match /invites/{id} {
      allow read: if isSuperadmin()
        || (isSchoolAdmin() && resource.data.schoolId == myUser().schoolId)
        || (signedIn() && resource.data.email == request.auth.token.email);
      allow create: if request.resource.data.role in ['admin', 'teacher', 'student', 'parent']
        && (isSuperadmin()
            || (isSchoolAdmin() && request.resource.data.schoolId == myUser().schoolId));
      allow delete: if isSuperadmin()
        || (isSchoolAdmin() && resource.data.schoolId == myUser().schoolId);
      allow update: if isSuperadmin()
        || (isSchoolAdmin() && resource.data.schoolId == myUser().schoolId)
        || (signedIn() && resource.data.email == request.auth.token.email);
    }

    // Audit trail (admin action history) — append-only. A Super Admin reads
    // all; a School Admin reads their own school. Entries are immutable (no
    // update/delete) so the history is retained even after accounts are purged.
    // create requires the writer to stamp themselves as the actor.
    match /audit_logs/{id} {
      allow read: if isSuperadmin()
        || (isSchoolAdmin() && resource.data.schoolId == myUser().get('schoolId', ''));
      allow create: if (isSuperadmin() || isSchoolAdmin())
        && request.resource.data.actorId == request.auth.uid;
    }

    // Learning goals — private to the student who created them (query by userId).
    match /goals/{id} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // Class resources (shared library) — readable by any signed-in user (so a
    // `where classId ==` query is allowed, same model as classes/assignments/
    // quiz_results above); only the owning teacher can add or remove them.
    // (Resources are teacher-shared class materials, not private data.)
    match /resources/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.teacherId == request.auth.uid;
    }

    // In-app notifications — private to the recipient. Each user's client both
    // creates (addressed to itself) and reads only its own notifications.
    // `resource == null` lets a get() on a not-yet-created notification return
    // "missing" instead of being denied (used for the dedupe existence check).
    match /notifications/{id} {
      allow read: if signedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
