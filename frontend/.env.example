# Copy this file to .env.local and fill in your real values.

# Groq API key — get one at https://console.groq.com/keys
REACT_APP_GROQ_API_KEY=your-groq-api-key

# Firebase web config (from Firebase console > Project settings > Your apps).
# These are public client identifiers, not secrets, but are kept in env so they
# are easy to change per environment.
REACT_APP_FIREBASE_API_KEY=your-firebase-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id
