# Copy this file to .env and fill in your values.
NODE_ENV=development
PORT=5000

# Firebase Admin (only needed when NODE_ENV is not "development").
# In development the backend uses a mock Firebase implementation.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Resend (https://resend.com) — sends school invite emails. Without a key the
# /api/email/invite endpoint is a no-op (admins copy the invite link by hand).
# The sender must be on a domain you've verified in Resend (e.g.
# mail.rexplore.ai); onboarding@resend.dev works for testing to your own address.
# FROM_EMAIL may be a bare address (a friendly "MwanaAI <...>" name is added),
# or use RESEND_FROM for a full "Name <addr>" sender.
RESEND_API_KEY=
FROM_EMAIL=noreply@mail.rexplore.ai
